{
  "name": "whisper-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare:bundle:mac": "node scripts/configure-tauri.mjs macos-arm64",
    "prepare:bundle:mac:universal": "node scripts/configure-tauri.mjs macos-universal",
    "prepare:bundle:win": "node scripts/configure-tauri.mjs windows-x64",
    "build:mac": "npm run prepare:bundle:mac && tauri build",
    "build:win": "npm run prepare:bundle:win && tauri build --target x86_64-pc-windows-msvc",
    "package:mac:zip": "bash scripts/package-macos-app.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
