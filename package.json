{
  "name": "whisper-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "cleanup:mac:dmg": "bash scripts/cleanup-macos-dmg-mounts.sh",
    "prepare:bundle:mac": "node scripts/configure-tauri.mjs macos-arm64",
    "prepare:bundle:mac:intel": "node scripts/configure-tauri.mjs macos-x64",
    "prepare:bundle:mac:universal": "node scripts/configure-tauri.mjs macos-universal",
    "prepare:bundle:win": "node scripts/configure-tauri.mjs windows-x64",
    "prepare:ffmpeg:win": "node scripts/prepare-windows-ffmpeg.mjs",
    "build:mac": "npm run build:mac:arm",
    "build:mac:arm": "npm run cleanup:mac:dmg && node scripts/build-tauri.mjs macos-arm64 aarch64-apple-darwin",
    "build:mac:intel": "npm run cleanup:mac:dmg && node scripts/build-tauri.mjs macos-x64 x86_64-apple-darwin",
    "build:mac:universal": "npm run cleanup:mac:dmg && node scripts/build-tauri.mjs macos-universal universal-apple-darwin",
    "build:win": "npm run prepare:ffmpeg:win && node scripts/build-tauri.mjs windows-x64 x86_64-pc-windows-msvc",
    "package:mac:zip": "bash scripts/package-macos-app.sh",
    "package:mac:zip:arm": "bash scripts/package-macos-app.sh aarch64-apple-darwin",
    "package:mac:zip:intel": "bash scripts/package-macos-app.sh x86_64-apple-darwin",
    "verify:mac:deps": "bash scripts/verify-macos-binary-deps.sh src-tauri/resources/ffmpeg-macos-arm64 src-tauri/resources/ffmpeg-macos-x64"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "ffmpeg-static": "^5.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
